{
	"name": "x3p0-dev/x3p0-breadcrumbs",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"scripts": {
		"build": [
			"composer update --no-dev",
			"composer dump-autoload -a --no-dev"
		],
		"dev": [
			"composer update",
			"composer dump-autoload"
		],
		"post-install-cmd": [
			"@x3p0-dev-scripts"
		],
		"post-update-cmd": [
			"@x3p0-dev-scripts"
		],
		"zip": "composer archive --file=x3p0-breadcrumbs",
		"lint:php": "./vendor/bin/phpcs -d error_reporting=E_ALL^E_DEPRECATED -s --colors .",
		"fix:php": "./vendor/bin/phpcbf -d error_reporting=E_ALL^E_DEPRECATED -s --colors .",
		"x3p0-dev-scripts": "X3P0\\Breadcrumbs\\Scripts\\ComposerScripts::devScripts"
	},
	"autoload": {
		"psr-4": {
			"X3P0\\Breadcrumbs\\": "src/",
			"X3P0\\Breadcrumbs\\Packages\\ClassRegistry\\": "packages/x3p0-dev/x3p0-class-registry/src/",
			"X3P0\\Breadcrumbs\\Packages\\Event\\": "packages/x3p0-dev/x3p0-event/src/",
			"X3P0\\Breadcrumbs\\Packages\\Framework\\": "packages/x3p0-dev/x3p0-framework/src/",
			"X3P0\\Breadcrumbs\\Scripts\\": "scripts/"
		},
		"files" : [
			"src/functions-helpers.php"
		],
		"classmap": [
			"packages/"
		],
		"exclude-from-classmap": [
			"scripts/",
			"vendor/"
		]
	},
	"require": {
                "php": ">=8.1",
		"x3p0-dev/x3p0-class-registry": "dev-master",
		"x3p0-dev/x3p0-event": "dev-master",
		"x3p0-dev/x3p0-framework": "dev-master"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "*",
		"symfony/var-dumper": "^7.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"x3p0-dev/x3p0-prelude": "dev-master",
		"x3p0-dev/x3p0-skills": "dev-master"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"config": {
		"archive-dir": "./",
		"archive-format": "zip",
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"extra": {
		"x3p0": {
			"prelude": {
				"prefix": "X3P0\\Breadcrumbs\\Packages",
				"output-path": "packages",
				"packages": {
					"x3p0-dev/x3p0-class-registry": {
						"replace": "X3P0\\"
					},
					"x3p0-dev/x3p0-event": {
						"replace": "X3P0\\"
					},
					"x3p0-dev/x3p0-framework": {
						"replace": "X3P0\\"
					}
				}
			},
			"skills": {
				"path": ".claude/skills"
			}
		}
	},
	"archive": {
		"exclude": [
			"/vendor",
			"!/vendor/autoload.php",
			"!/vendor/composer/"
		]
	},
	"authors": [
		{
			"name": "Justin Tadlock",
			"email": "justintadlock@gmail.com"
		}
	]
}
